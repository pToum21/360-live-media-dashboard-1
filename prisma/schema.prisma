// 360 Live Media Marketing Dashboard Schema
// Based on Excel workbook analysis

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          String    @default("MARKETER") // ADMIN, MANAGER, MARKETER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // NextAuth Relations
  accounts      Account[]
  sessions      Session[]
  
  // App Relations
  websiteMetrics    WebsiteMetric[]
  emailCampaigns    EmailCampaign[]
  socialMetrics     SocialMetric[]
  socialPosts       SocialPost[]
  optimizations     Optimization[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// WEBSITE ANALYTICS
// ============================================

model WebsiteMetric {
  id                    String    @id @default(cuid())
  weekStarting          DateTime
  
  // SEMrush
  healthScore           Float?
  
  // Google Analytics
  totalUsers            Int
  percentChangeUsers    Float?
  newUsers              Int
  percentChangeNewUsers Float?
  
  // Traffic Sources
  referral              Int?
  organicSearch         Int?
  direct                Int?
  organicSocial         Int?
  email                 Int?
  unassigned            Int?
  
  // Engagement
  avgEngagementTimeSec  Int?
  percentChangeEngTime  Float?
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([weekStarting])
  @@index([clientId])
}

// ============================================
// EMAIL CAMPAIGNS
// ============================================

model EmailCampaign {
  id              String    @id @default(cuid())
  name            String
  deploymentDate  DateTime
  
  // Metrics
  openRate        Float
  clickRate       Float
  deliveryRate    Float
  unsubscribeRate Float
  
  // Client Association
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdById     String
  
  @@index([deploymentDate])
  @@index([clientId])
}

// ============================================
// SOCIAL MEDIA
// ============================================

model SocialMetric {
  id                    String    @id @default(cuid())
  weekStarting          DateTime
  
  // LinkedIn
  liFollowerGrowthRate  Float?
  liImpressions         Int?
  liEngagementRate      Float?
  liPostsPerWeek        Int?
  liFollowers           Int?
  
  // Instagram
  igImpressions         Int?
  igEngagementRate      Float?
  igPostsPerWeek        Int?
  igFollowers           Int?
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([weekStarting])
  @@index([clientId])
}

model SocialPost {
  id              String    @id @default(cuid())
  weekStarting    DateTime
  postUrl         String?
  platform        String    // LINKEDIN or INSTAGRAM
  
  // Metrics
  impressions     Int
  engagements     Int
  engagementRate  Float
  linkClicks      Int?
  
  // Client Association
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdById     String
  
  // Relations
  tags            PostTag[]
  
  @@index([weekStarting])
  @@index([platform])
  @@index([clientId])
}

// ============================================
// CONTENT TAGGING SYSTEM
// ============================================

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  category    String    // AUDIENCE or CONTENT
  description String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  posts       PostTag[]
}

model PostTag {
  id          String    @id @default(cuid())
  post        SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String
  tag         Tag       @relation(fields: [tagId], references: [id])
  tagId       String
  
  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
}

// ============================================
// CAMPAIGN TRACKING
// ============================================

model Campaign {
  id          String    @id @default(cuid())
  month       String
  source      String
  pageViews   Int
  
  // Client Association
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([month])
  @@index([source])
  @@index([clientId])
}

// ============================================
// CLIENT ORGANIZATIONS
// ============================================

model Client {
  id                    String    @id @default(cuid())
  name                  String    @unique
  slug                  String?   @unique // URL-friendly identifier
  logo                  String?
  
  // Project Details (optional)
  eventName             String?
  year                  Int?
  campaignStatus        String?
  dashboardStatus       String?
  
  // Tracking Status
  utmTracking           Boolean   @default(false)
  conversionTracking    Boolean   @default(false)
  
  // Notes
  issueDescription      String?
  nextSteps             String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations - all data belongs to a client
  websiteMetrics        WebsiteMetric[]
  emailCampaigns        EmailCampaign[]
  socialMetrics         SocialMetric[]
  socialPosts           SocialPost[]
  campaigns             Campaign[]
  optimizations         Optimization[]
  
  @@index([slug])
}

// ============================================
// A/B TESTING & OPTIMIZATIONS
// ============================================

model Optimization {
  id              String    @id @default(cuid())
  month           String
  channel         String?
  controlTest     String?   // The "A"
  testVariant     String?   // The "B"
  results         String?
  conclusions     String?
  
  // Client Association
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdById     String
  
  @@index([month])
  @@index([clientId])
}

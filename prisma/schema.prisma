// 360 Live Media Marketing Dashboard Schema
// Based on Excel workbook analysis

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          String    @default("MARKETER") // ADMIN, MANAGER, MARKETER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // NextAuth Relations
  accounts      Account[]
  sessions      Session[]
  
  // App Relations
  websiteMetrics       WebsiteMetric[]
  emailCampaigns       EmailCampaign[]
  salesMarketing       SalesMarketing[]
  socialMetrics        SocialMetric[]
  socialPosts          SocialPost[]
  optimizations        Optimization[]
  paidMedia            PaidMedia[]
  eventRegistrations   EventRegistration[]
  passTypes            PassType[]
  abstractSubmissions  AbstractSubmission[]
  revenueProjections   RevenueProjection[]
  ga4Registrations     GA4Registration[]
  calendarEvents       CalendarEvent[]
  shareLinks           ShareLink[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// WEBSITE ANALYTICS
// ============================================

model WebsiteMetric {
  id                    String    @id @default(cuid())
  weekStarting          DateTime
  
  // SEMrush
  healthScore           Float?
  
  // Google Analytics
  totalUsers            Int
  percentChangeUsers    Float?
  newUsers              Int
  percentChangeNewUsers Float?
  
  // Traffic Sources
  referral              Int?
  organicSearch         Int?
  direct                Int?
  organicSocial         Int?
  email                 Int?
  unassigned            Int?
  paidSocial            Int?      // For ATC - Paid social ads
  paidSearch            Int?      // For ATC - Paid search ads
  
  // Engagement
  avgEngagementTimeSec  Int?
  percentChangeEngTime  Float?
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([weekStarting])
  @@index([clientId])
}

// ============================================
// EMAIL CAMPAIGNS
// ============================================

model EmailCampaign {
  id              String    @id @default(cuid())
  name            String
  deploymentDate  DateTime

  // Segmentation
  audience        String?   // e.g., "Members", "Sponsors", "Attendees", "All"
  campaignType    String?   // e.g., "Newsletter", "Promotion", "Announcement"

  // Timing Analysis (for send time optimization)
  deploymentDayOfWeek String?  // e.g., "Monday", "Friday"
  deploymentTimeOfDay String?  // e.g., "Morning", "Afternoon", "Evening"
  deploymentHour      Int?     // Hour of day (0-23) for precise time analysis

  // Metrics
  openRate        Float
  clickRate       Float
  deliveryRate    Float
  unsubscribeRate Float

  // Benchmarks (for ATC - industry standards)
  openRateBenchmark       Float?
  clickRateBenchmark      Float?
  deliveryRateBenchmark   Float?
  unsubscribeRateBenchmark Float?

  // Additional ATC fields
  totalSent       Int?
  subjectLine     String?
  
  // Email Click Heatmap Data (where recipients click)
  totalClicks          Int?
  topButtonClicks      Int?
  topButtonClickPct    Float?   // % of total clicks
  topLogoClicks        Int?
  topLogoClickPct      Float?
  headerImageClicks    Int?
  headerImageClickPct  Float?
  bodyContentClicks    Int?
  bodyContentClickPct  Float?
  footerClicks         Int?
  footerClickPct       Float?

  // Client Association
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdById     String

  @@index([deploymentDate])
  @@index([clientId])
  @@index([audience])
  @@index([campaignType])
  @@index([deploymentDayOfWeek])
}

// ============================================
// SALES MARKETING / PROMO CAMPAIGNS
// ============================================

model SalesMarketing {
  id              String    @id @default(cuid())
  weekOf          DateTime
  targetSendDate  DateTime?
  audience        String?
  subjectMessage  String?
  opportunities   String?
  notes           String?
  status          String?
  finalLink       String?
  sent            String?
  reportSent      String?
  
  // Metrics
  micrositeVisits Int?
  openRate        Float?
  clickRate       Float?
  bounces         Int?
  unsubs          Int?
  
  // Client Association
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdById     String
  
  @@index([weekOf])
  @@index([clientId])
}

// ============================================
// GA4 REGISTRATION TRACKING BY TRAFFIC SOURCE
// ============================================

model GA4Registration {
  id                String    @id @default(cuid())
  weekStarting      DateTime
  weekLabel         String?   // e.g., "1/5 - 1/11" or "Week 24"
  weeksOut          Int?      // Weeks until event (e.g., 24, 23, 22...)
  
  // Registration counts by traffic source (GA4 acquisition)
  organicSearch     Int?
  email             Int?
  direct            Int?
  paidSocial        Int?
  paidSearch        Int?
  referral          Int?
  organicSocial     Int?
  unassigned        Int?
  
  // Total registrations for this week
  totalRegistrations Int?
  
  // Client Association
  client            Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId          String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         User      @relation(fields: [createdById], references: [id])
  createdById       String
  
  @@index([weekStarting])
  @@index([clientId])
  @@index([weeksOut])
}

// ============================================
// SOCIAL MEDIA
// ============================================

model SocialMetric {
  id                    String    @id @default(cuid())
  weekStarting          DateTime
  
  // LinkedIn
  liFollowerGrowthRate  Float?
  liImpressions         Int?
  liEngagementRate      Float?
  liPostsPerWeek        Int?
  liFollowers           Int?
  
  // Instagram
  igImpressions         Int?
  igEngagementRate      Float?
  igPostsPerWeek        Int?
  igFollowers           Int?
  
  // Facebook (for ATC)
  fbFollowers           Int?
  fbFollowerGrowthRate  Float?
  fbImpressions         Int?
  fbEngagements         Int?
  fbPostsPerWeek        Int?
  
  // Twitter/X (for ATC)
  xFollowers            Int?
  xFollowerGrowthRate   Float?
  xImpressions          Int?
  xEngagements          Int?
  xPostsPerWeek         Int?
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([weekStarting])
  @@index([clientId])
}

model SocialPost {
  id              String    @id @default(cuid())
  weekStarting    DateTime
  postUrl         String?
  platform        String    // LINKEDIN or INSTAGRAM
  
  // Metrics
  impressions     Int
  engagements     Int
  engagementRate  Float
  linkClicks      Int?
  
  // Client Association
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdById     String
  
  // Relations
  tags            PostTag[]
  
  @@index([weekStarting])
  @@index([platform])
  @@index([clientId])
}

// ============================================
// CONTENT TAGGING SYSTEM
// ============================================

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  category    String    // AUDIENCE or CONTENT
  description String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  posts       PostTag[]
}

model PostTag {
  id          String    @id @default(cuid())
  post        SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId      String
  tag         Tag       @relation(fields: [tagId], references: [id])
  tagId       String
  
  @@unique([postId, tagId])
  @@index([postId])
  @@index([tagId])
}

// ============================================
// CAMPAIGN TRACKING
// ============================================

model Campaign {
  id          String    @id @default(cuid())
  month       String
  source      String
  pageViews   Int
  
  // Client Association
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([month])
  @@index([source])
  @@index([clientId])
}

// ============================================
// CLIENT ORGANIZATIONS
// ============================================

model Client {
  id                    String    @id @default(cuid())
  name                  String    @unique
  slug                  String?   @unique // URL-friendly identifier
  logo                  String?
  
  // Project Details (optional)
  eventName             String?
  year                  Int?
  campaignStatus        String?
  dashboardStatus       String?
  
  // Tracking Status
  utmTracking           Boolean   @default(false)
  conversionTracking    Boolean   @default(false)
  
  // Notes
  issueDescription      String?
  nextSteps             String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations - all data belongs to a client
  websiteMetrics        WebsiteMetric[]
  emailCampaigns        EmailCampaign[]
  salesMarketing        SalesMarketing[]         // For ATC - Sales marketing / promo campaigns
  socialMetrics         SocialMetric[]
  socialPosts           SocialPost[]
  campaigns             Campaign[]
  optimizations         Optimization[]
  paidMedia             PaidMedia[]              // For ATC - Paid advertising
  eventRegistrations    EventRegistration[]      // For ATC - Event registration tracking
  passTypes             PassType[]               // For ATC - Ticket/pass type breakdown
  abstractSubmissions   AbstractSubmission[]     // For ATC - Abstract submissions
  revenueProjections    RevenueProjection[]      // For ATC - Revenue projections
  ga4Registrations      GA4Registration[]        // For ATC - GA4 registration tracking by traffic source
  calendarEvents        CalendarEvent[]          // Marketing calendar events
  shareLinks            ShareLink[]              // Shareable dashboard links
  
  @@index([slug])
}

// ============================================
// A/B TESTING & OPTIMIZATIONS
// ============================================

model Optimization {
  id              String    @id @default(cuid())
  month           String
  channel         String?
  controlTest     String?   // The "A"
  testVariant     String?   // The "B"
  results         String?
  conclusions     String?
  
  // Client Association
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdById     String
  
  @@index([month])
  @@index([clientId])
}

// ============================================
// PAID MEDIA (for ATC)
// ============================================

model PaidMedia {
  id                    String    @id @default(cuid())
  weekStarting          DateTime
  
  // LinkedIn Ads
  liImpressions         Int?
  liClicks              Int?
  liSpend               Float?
  liCPC                 Float?
  liCTR                 Float?
  liConversions         Int?
  liCVR                 Float?
  liCPA                 Float?
  
  // Meta Ads (Facebook + Instagram)
  metaImpressions       Int?
  metaClicks            Int?
  metaSpend             Float?
  metaCPC               Float?
  metaCTR               Float?
  metaConversions       Int?
  metaCVR               Float?
  metaCPA               Float?
  
  // Google Search
  googleSearchImpressions Int?
  googleSearchClicks      Int?
  googleSearchSpend       Float?
  googleSearchCPC         Float?
  googleSearchCTR         Float?
  googleSearchConversions Int?
  googleSearchCVR         Float?
  googleSearchCPA         Float?
  
  // Google Display
  googleDisplayImpressions Int?
  googleDisplayClicks      Int?
  googleDisplaySpend       Float?
  googleDisplayCPC         Float?
  googleDisplayCTR         Float?
  googleDisplayConversions Int?
  googleDisplayCVR         Float?
  googleDisplayCPA         Float?
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([weekStarting])
  @@index([clientId])
}

// ============================================
// EVENT REGISTRATIONS (for ATC)
// ============================================

model EventRegistration {
  id                    String    @id @default(cuid())
  date                  DateTime
  
  // Registration Counts
  totalRegistrations    Int
  compRegistrations     Int?      // Comp/Free registrations
  paidRegistrations     Int?      // Paid registrations
  
  // Revenue (if available)
  revenue               Float?
  
  // Registration Types (pass types)
  memberCount           Int?
  nonMemberCount        Int?
  studentCount          Int?
  sponsorCount          Int?
  
  // Goals
  registrationGoal      Int?
  percentOfGoal         Float?
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([date])
  @@index([clientId])
}

// ============================================
// PASS TYPES / TICKET TYPES (for ATC)
// ============================================

model PassType {
  id                    String    @id @default(cuid())
  passTypeName          String
  year                  Int
  registrationCount     Int
  percentOfTotal        Float?
  revenue               Float?
  isPaid                Boolean   @default(true)
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([year])
  @@index([clientId])
}

// ============================================
// ABSTRACTS / SUBMISSIONS (for ATC)
// ============================================

model AbstractSubmission {
  id                    String    @id @default(cuid())
  year                  Int
  submissionCount       Int
  submissionType        String?   // e.g., "Late-Breaking", "Regular"
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([year])
  @@index([clientId])
}

// ============================================
// REVENUE PROJECTIONS (for ATC)
// ============================================

model RevenueProjection {
  id                    String    @id @default(cuid())
  date                  DateTime
  projectedRevenue      Float?
  actualRevenue         Float?
  projectedRegistrations Int?
  actualRegistrations   Int?
  category              String?   // e.g., "Members", "Sponsors", "Exhibitors"
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([date])
  @@index([clientId])
}

// ============================================
// MARKETING CALENDAR
// ============================================

model CalendarEvent {
  id                    String    @id @default(cuid())
  date                  DateTime
  title                 String
  description           String?
  
  // Category from Excel Content KEY
  category              String?   // "Important Date", "ATC Attendee Marketing", "ATC Exhibitor Marketing", etc.
  
  // Visual properties
  color                 String?   // Hex color for calendar display
  
  // Time (if specific time is needed)
  startTime             String?   // e.g., "09:00"
  endTime               String?   // e.g., "17:00"
  allDay                Boolean   @default(true)
  
  // Additional metadata
  location              String?
  url                   String?
  notes                 String?
  
  // Status
  status                String?   // "Planned", "In Progress", "Completed", "Cancelled"
  
  // Client Association
  client                Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  @@index([date])
  @@index([clientId])
  @@index([category])
}

// ============================================
// SHAREABLE DASHBOARD LINKS
// ============================================

model ShareLink {
  id                    String    @id @default(cuid())
  
  // What client dashboard to share
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String
  
  // Who created this share link
  createdBy             User      @relation(fields: [createdById], references: [id])
  createdById           String
  
  // Link configuration
  isActive              Boolean   @default(true)
  expiresAt             DateTime?
  
  // Analytics summary
  viewCount             Int       @default(0)
  lastViewedAt          DateTime?
  
  // Timestamps
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations
  views                 ShareLinkView[]
  
  @@index([clientId])
  @@index([createdById])
  @@index([isActive])
}

model ShareLinkView {
  id                    String    @id @default(cuid())
  
  // Which share link was accessed
  shareLink             ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  shareLinkId           String
  
  // View details
  viewedAt              DateTime  @default(now())
  ipAddress             String?
  userAgent             String?
  
  // Engagement tracking
  durationSeconds       Int?      // How long they stayed
  pagesViewed           String[]  // Array of pages they visited (e.g., ["dashboard", "email", "social"])
  
  @@index([shareLinkId])
  @@index([viewedAt])
}
